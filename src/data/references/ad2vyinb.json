  "segments": [
    { "uuid": "gni47p1l", "segment": "Les pièces d'un mach" },
    { "uuid": "bsamx0ud", "segment": "Par un édit de 1837, « il est statué aux termes de la loi que les très" },
    { "uuid": "vkhs2w9g", "segment": "grandes monnaies de cuivre portant des inscriptions morales auront cha-" },
    { "uuid": "cysftqfq", "segment": "cune la valeur d'un mach ; lorsqu'on s'en servira dans les transactions," },
    { "uuid": "ay7igh1t", "segment": "leur valeur est ainsi arrêtée pour tous ». (Schroeder : 268). Sous Tự Đức," },
    { "uuid": "i5nl9of4", "segment": "on reprend les types de Minh Mang, dont certaines inscriptions paraissent" },
    { "uuid": "sotk27bb", "segment": "alors totalement antinomiques par rapport à la situation du pays, comme " },
    { "uuid": "1xt0kw8m", "segment": "Quốc phú, binh cường, nội an, ngoại tĩnh" },
    { "uuid": "17j11n8i", "segment": ", « Enrichir le pays, affermir l'ar-" },
    { "uuid": "8718zgsy", "segment": "mée, paix intérieure et calme extérieur », et on en ajoute d'autres tout aussi" },
    { "uuid": "pgcjwvst", "segment": "antithétiques à la pratique comme" },
    { "uuid": "2tnzdbgf", "segment": "" },
    { "uuid": "h0jt4wev", "segment": "Thụ lộc vu thiên, bảo hựu mạng chi" },
    { "uuid": "x71rdmyj", "segment": "," },
    { "uuid": "33vt3i9x", "segment": "« Comblé d'honneurs par le Ciel, il en préserve le Mandat » (fig. 6," },
    { "uuid": "jqo4sqcm", "segment": "CMV: 1827). La valeur monétaire de ces pièces n'est pas modifiée et leur" },
    { "uuid": "5yb3s0jk", "segment": "circulation est attestée par le coffret de changeur conservé au Musée moné-" },
    { "uuid": "4b2y4fvu", "segment": "taire de l'Administration des Monnaies et Médailles qui comptait 5 ligatures" },
    { "uuid": "qnsoopaz", "segment": "de 10 de ces pièces, ce qui correspond à la valeur de 5 quan (AMM : 74-75)." }
  ],
