  "segments": [
    { "uuid": "i6l29p37", "segment": "Đúc tiền đồng lớn mỹ hiệu \"Minh Mệnh thông bảo\" 1 vạn đồng. Sai Hộ bộ Thị" },
    { "uuid": "x4e59zl8", "segment": "vệ hội đồng với đốc công Vũ khố, chiếu chữ hiệu và quy thức đã định mà đúc 20" },
    { "uuid": "89d4mk6c", "segment": "hiệu 8 chữ :" },
    { "uuid": "4ay17vdv", "segment": "1. Hiền hiền thân thân" },
    { "uuid": "ms2h44p7", "segment": "- Lạc lạc lợi lợi" },
