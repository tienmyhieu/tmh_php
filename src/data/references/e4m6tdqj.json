  "maxims": [
    { "uuid": "ixvzdp6v", "segment": "Mutual equity between prince and liege; mutual affection between father and children." },
    { "uuid": "i93217p7", "segment": "to estimate the men of parts and of uncommon vietus (to love and seek the wise men; to love one's parent to cherish ones relative, to enjoy peace; to profit by good fortune)" },
    { "uuid": "q5hobbfw", "segment": "The state is prosperious; tne Nation is quiet, the wind and the rain at the right moment and to the right amount." },
    { "uuid": "o2qqponq", "segment": "(may you enjoy) the 3 wishes of Hoan and also of the 9 similitudes of thien bao." },
    { "uuid": "uaz39591", "segment": "To obtain the throne; to securee affluence to gain a good renown ; to live a long life" },
    { "uuid": "muuzk32t", "segment": "The six treasures of Nature have been greatly improved, the 3 professions are well ordered" },
    { "uuid": "hov4yrxv", "segment": "Eminetly just, eminently irreproachable to have no party spirit, not being predisposed towards one side or another." },
    { "uuid": "sahho0en", "segment": "May the Emperor live 10,000 times 10,000 years." },
    { "uuid": "4aqdvu02", "segment": "Profoundly virtuous and perfect, with a grave demeanour and a respectful bearing." },
    { "uuid": "s8pnyg48", "segment": "May the rivers have an invariably favorable stream ; may the seeds come to maturity ani in aboundance each year" },
    { "uuid": "2z84bcmz", "segment": "To love one's parents, to have regard for one's betters, to honor the old ones, to cherish the young children" },
    { "uuid": "p4u26dou", "segment": "To enrich the kingdom ; to consolidate the army ; safety in the kingdom, Peace out of the kingdom." },
    { "uuid": "jko5x6ei", "segment": "May your wealth increase and be like a mountain-crest, like a hillock." },
    { "uuid": "xa530hbp", "segment": "A prosperity as immense as the Oriental Sea, a longevity that can be compared to Southern Mountain." },
    { "uuid": "xaxylg8g", "segment": "To be granted a life 10,000 years, and laden with blessing." },
    { "uuid": "10c9iwta", "segment": "The heaven will not square its blessings, neither will the earth spare its treasures." },
    { "uuid": "tppm9wee", "segment": "His adorments are chiselled, and well wrought, they are made of gold and precious stones." },
    { "uuid": "ppmr3mqo", "segment": "the way of the sovereign is broad and extends far away; the wise men's views are of far reaching effect." },
    { "uuid": "gwnm2qfm", "segment": "The sovereign will be happy, he will live 10,000 years, he will live forever." },
    { "uuid": "sh9fdswe", "segment": "Being adapted to the different seasons, all the works will be carried out perfectly." },
    { "uuid": "k6oqxq6w", "segment": "With the help of god, everything becomes propitious and prosperous." },
    { "uuid": "c5vodtl0", "segment": "The empire renders homage to him and all the centuries will proclain his name." },
    { "uuid": "v620m797", "segment": "To engage at present in good works, to extend one's blessing to 10,000 generations." },
    { "uuid": "h14pvl29", "segment": "beginning, development, strengthing, and improving." },
    { "uuid": "2dir1y3t", "segment": "To enjoy a constant and certain felicity." },
    { "uuid": "tor8ac2f", "segment": "The emperous' virtue is boundless and always active" },
    { "uuid": "ve2sruy5", "segment": "To obtain the riquired objects and to get the commodities of life" },
    { "uuid": "jblvyygh", "segment": "By poise and harmony, things are in there right place and living creatures reproduce." },
    { "uuid": "mj7x5x5k", "segment": "to obtain the five felicities, to make the nation share them" },
    { "uuid": "yd6x4clp", "segment": "To be the model of the whole enpire." },
    { "uuid": "ilvzpsg1", "segment": "Firm, strong, to keep the golden mean, not inclined to one thing or another." },
    { "uuid": "r97gdhdx", "segment": "The nation lives in abundance." },
    { "uuid": "hwj4rx5q", "segment": "May all the meals be plentiful and always increase." },
    { "uuid": "8euowcta", "segment": "A great concord reigns over the whole empire." },
    { "uuid": "93iq7ond", "segment": "All the generations will reap the fruits of it for ever." },
    { "uuid": "dqpq76ol", "segment": "All the being derive from the earth there origin and there means of living." },
    { "uuid": "bh2lskki", "segment": "To appease hatred, to increase the weith." },
    { "uuid": "zlbi23aa", "segment": "Its range and its duration are boundless." },
    { "uuid": "s1apymmy", "segment": "To obtain as a reward 10,000 years of life." },
    { "uuid": "gji6zrfk", "segment": "The prosperous state renders the nation happy." },
    { "uuid": "m269aw0x", "segment": "With the help of the heaven, everything becomes faverable and a properous." },
    { "uuid": "4mbfgvev", "segment": "To obtain as a reward 10,000 years of life." },
    { "uuid": "r2khkj8m", "segment": "To love one's parents, to respect one's superiors, to honor the old men, to cherish the young children." },
    { "uuid": "b15y92xb", "segment": "Firm, strong, keeping to the golden mean, to be impartial." },
    { "uuid": "1n2djuv2", "segment": "The heaven overwhelms him with blessings protects him, helps him, give him power." },
    { "uuid": "gc68h3jz", "segment": "(The real perfection is high and brillant like the heaven, broad and deep like the earth" },
    { "uuid": "yvo61nte", "segment": "In the whole empire there appears no reason to worry about, this prosperity will extand to the future negerations." },
    { "uuid": "0pqaew9d", "segment": "Felicety and honours come in all their plenitude." },
    { "uuid": "bygcsqxj", "segment": "The whole nation feels a sincere affection for him." },
    { "uuid": "r5b3iv67", "segment": "Abundance of riches for the community and for indiduals." },
    { "uuid": "n2b2hlnk", "segment": "The 9 works must be completed in order." }
  ],
