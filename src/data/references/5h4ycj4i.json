  "segments": [
    { "uuid": "376rvtnu", "segment": "Đúc tiền đồng lớn, mỹ hiệu “Thiệu Trị”, tất cả 40 thứ là 10.000 đồng. Mỗi thứ" },
    { "uuid": "99zxtt29", "segment": "tiền có các chữ sau đây :" },
    { "uuid": "k0vs1yj7", "segment": "- Thân thân, trưởng trưởng, lão lão, ấu ấu" },
    { "uuid": "2ooq2nq3", "segment": "- Chí công, chí chính, vô đảng, vô thiên" },
    { "uuid": "vf6bl858", "segment": "- Quốc phú, binh cường, nội an, ngoại tĩnh" },
    { "uuid": "o8y1qf4c", "segment": "- Ngũ thời thuận phủ, thử tích kỳ ngưng" },
    { "uuid": "z95k86u2", "segment": "- Vạn tuế, vạn tuế, vạn vạn tuế thọ" },
    { "uuid": "i8gu31ky", "segment": "- Phước như Đông hải, thọ tỷ Nam sơn" },
    { "uuid": "rsiite61", "segment": "- Hà lưu thuận quỹ, niên cốc phong đăng" },
    { "uuid": "k78ywlas", "segment": "- Vạn thọ du tạc, vạn Phước du đồng" },
    { "uuid": "4vanixws", "segment": "- Như sơn, như xuyên, như cương, như phụ" },
    { "uuid": "22fl3j1l", "segment": "- Đắc vị, đắc lộc, đắc danh, đắc thọ" },
    { "uuid": "n0v4a9lg", "segment": "- Quốc thái, dân an, phong điều, vũ thuận" },
    { "uuid": "0fl4yims", "segment": "- Thân thân, hiền hiền, lợi lợi, lạc lạc" },
    { "uuid": "ugn9gawo", "segment": "- Nhất nhân hữu khánh, vạn thọ vô cương" },
    { "uuid": "rw5zduhv", "segment": "- Quân quân, thần thần, phụ phụ, tử tử" },
    { "uuid": "4q24bnfp", "segment": "- Lục phủ khổng tu, tam sự doãn trị" },
    { "uuid": "lnbny0mm", "segment": "- Truy trác kỳ chương, kim ngọc kỳ tương" },
    { "uuid": "3wc54x2h", "segment": "- Mục mục, hoàng hoàng, tể tể, thương thương" },
    { "uuid": "8bdn1jnd", "segment": "- Vương đạo đãng đãng, thánh mô dương dương" },
    { "uuid": "n0pb5o47", "segment": "- Tứ hải cộng chi, bách thế truyền chi" },
    { "uuid": "xkrvhj6i", "segment": "- Tự thiên hựu chi, cát vô bất lợi" },
    { "uuid": "8kjzpgxa", "segment": "- Nhất nhân hữu khánh, triệu dân lại chi" },
    { "uuid": "2uqwyefh", "segment": "- Trạch cập đương thời, ân thuỳ vạn thế" },
    { "uuid": "nmg8oi8y", "segment": "- Thiên bất ái đạo, địa bất ái bảo" },
