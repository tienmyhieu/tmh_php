  "segments": [
    { "uuid": "z4kklsm7", "segment": "Năm 18, Dụ rằng : Tiền đồng lớn mừng hiệu, trước đã đúc," },
    { "uuid": "vm82lj8y", "segment": "nhưng vẫn không nhiều. Vậy cho 2 bộ Hộ và Công, cùng Đô sát, thị" },
    { "uuid": "0c974xln", "segment": "vệ, mỗi nơi phái 1 người thuộc viên hội đồng với viên đốc công, cử" },
    { "uuid": "3p396qsf", "segment": "Vũ khố lấy ra đồng thiếc kẽm hạng tốt theo phép phối hợp nấu lên" },
    { "uuid": "d6h43zx4", "segment": "mà đúc tiền, vẫn cho theo cách thức và chữ hiệu năm trước đúc" },
    { "uuid": "0jqmvt6u", "segment": "100.000 đồng tiền." },
    { "uuid": "ln0o9vl6", "segment": "Xét các mỹ tự trong đồng tiền, thì về hạng 8 chữ có 23 hiệu là:" },
    { "uuid": "wvd4ur0m", "segment": "Quân quân, thần thần, phụ phụ, tử tử." },
    { "uuid": "8jd1h269", "segment": "Hiền hiền, thân thân, lạc lạc, lợi lợi." },
    { "uuid": "yzr0jkng", "segment": "Quốc thái dân an, phong điều vũ thuận." },
    { "uuid": "8cm27mx6", "segment": "Hoa phong tam chúc, thiên bảo cửu như." },
    { "uuid": "s1tutzwp", "segment": "Đắc vị đắc danh, đắc danh đắc thọ." },
    { "uuid": "i98zgpd1", "segment": "Lục phủ khổng tu, tam sự doãn trị." },
    { "uuid": "aj7t4xbp", "segment": "Chí công chí chính, vô đảng vô thiên." },
    { "uuid": "p1zcbpw5", "segment": "Vạn tuế vạn tuế, vạn vạn tuế thọ." },
    { "uuid": "zjwzq2tl", "segment": "Mục mục hoàng hoàng, tế tể xương xương." },
    { "uuid": "s7tp18hg", "segment": "Hà lưu thuận quĩ, niên cốc phong đăng." },
    { "uuid": "2zyo09t6", "segment": "Thân thân trưởng trưởng, lão lão ấu ấu." },
    { "uuid": "e4feq4f4", "segment": "Quốc phú binh cường, nội an ngoại tĩnh." },
    { "uuid": "gzq6al25", "segment": "Như sơn như xuyên, như cương như nhụ." },
    { "uuid": "pg3cnuj8", "segment": "Phúc như Đông hải, thọ tỷ nam sơn." },
    { "uuid": "jw4fsvtg", "segment": "Vạn thọ du tạc, vạn phúc du đồng." },
    { "uuid": "at4ogs25", "segment": "Thiên bất ái đạo, địa bất ái bảo." },
    { "uuid": "bcbbx25o", "segment": "Truy trác kỳ chương, kim ngọc kỳ tương." },
    { "uuid": "1hjpvzs8", "segment": "Vương đạo đãng đãng, mô đạo dương dương." },
    { "uuid": "jrvi4sca", "segment": "Nhất nhân hữu khánh, vạn thọ vô cương." },
    { "uuid": "tyagsxbe", "segment": "Ngũ thời thuận phủ, thứ tích kỳ ngưng." },
    { "uuid": "x0dpk926", "segment": "Tự thiên hựu chi, cát vô bất lợi." },
    { "uuid": "8yjk63he", "segment": "Tứ hải cộng chi, vạn thế truyền chi." },
    { "uuid": "1bn6ul52", "segment": "Trạch cập đương thời, ân thùy vạn thế." },
    { "uuid": "77dossey", "segment": "Hạng 4 chữ có 17 hiệu là:" },
    { "uuid": "3ntylm8m", "segment": "Nguyên hanh lợi trinh." },
    { "uuid": "tm818keh", "segment": "Xuyên chí sơn tăng." },
    { "uuid": "3vvpou1p", "segment": "Phúc lỷ tuy tướng." },
    { "uuid": "oilb2uzx", "segment": "Thiên hạ đại đồng." },
    { "uuid": "qbqcrb5e", "segment": "Đế đức quảng vận." },
    { "uuid": "mjbw995g", "segment": "Vạn thế vĩnh lại." },
    { "uuid": "fuxphrlb", "segment": "Lợi dụng hậu sinh." },
    { "uuid": "lemfxmv4", "segment": "Vạn vật tư sinh." },
    { "uuid": "1fte9ct4", "segment": "Trung hoà vị dục." },
    { "uuid": "pbgdejtb", "segment": "Giải uấn phụ tài." },
    { "uuid": "edcov6gm", "segment": "Liễm phúc tích dân." },
    { "uuid": "ngf8zmfv", "segment": "Du cửu vô cương." },
    { "uuid": "l3bszrge", "segment": "Tứ phương vi tắc." },
    { "uuid": "wgp06p4y", "segment": "Thọ khảo vạn niên." },
    { "uuid": "kt1tl5ds", "segment": "Cương kiện trung chính." },
    { "uuid": "aeowfdd1", "segment": "Vị quốc lợi dân." },
    { "uuid": "5i81zf70", "segment": "Gia cấp nhân túc." },
    { "uuid": "2tnzdbgf", "segment": "" }
  ],
