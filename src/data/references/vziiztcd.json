  "segments": [
    { "uuid": "85ntnpoy", "segment": "參制之法雖照與部議不無差異而鑄成錢交呈式" },
    { "uuid": "9ujlrhaj", "segment": "亦覺棈好准依此行〇十九年" },
    { "uuid": "ox6stf3s", "segment": "旨此次開設場局本為便民前者鑄以一初建設承辨" },
    { "uuid": "agtmuuwg", "segment": "拮据故不忍嚴為程督茲該等應工漸就嫺熟著再" },
    { "uuid": "nnsi84cx", "segment": "行依例鼔鑄俾雇借之民有所資仰〇十八年" },
    { "uuid": "qkc31fir", "segment": "諭美號大銅錢前經鑄造頗覺無多茲著戸工二部都" },
    { "uuid": "16x3b6t8", "segment": "察侍衞派屬一人會同督工員據武庫支出好項銅" },
    { "uuid": "o40gv4ax", "segment": "錫鉛依法搭配煮鍊仍依年前字號規式鑄造一十" },
    { "uuid": "mgoq3mhg", "segment": "萬文" },
    { "uuid": "nbuq1pqn", "segment": "謹按美字各號内八字二十三號" },
    { "uuid": "0l9yhcmd", "segment": "君君臣臣父父子子" },
    { "uuid": "fnpzijc8", "segment": "賢賢親親樂樂利利" },
    { "uuid": "8bh9llov", "segment": "國泰民安風調雨順" },
    { "uuid": "un8h6zz9", "segment": "華封三祝天保九如" },
    { "uuid": "3s6kumli", "segment": "得位得祿得名得壽" },
    { "uuid": "1p1kpuj3", "segment": "六府孔修三事允治" },
    { "uuid": "pqxgz61o", "segment": "欽定大南會典事例" },
    { "uuid": "0u9heof7", "segment": "戸部錢法" },
    { "uuid": "euq4sqd5", "segment": "鼓鑄卷五十三" },
    { "uuid": "c22x16j5", "segment": "七" },
    { "uuid": "4gpmxq1n", "segment": "至公至正無党無偏" },
    { "uuid": "4d86vo7j", "segment": "萬歳萬歳萬萬歳壽" },
    { "uuid": "aiw5ekw4", "segment": "穆穆皇皇擠擠蹌蹌" },
    { "uuid": "ahu8ea0i", "segment": "河流順軌年穀豐登" },
    { "uuid": "v1k0vmd5", "segment": "親親長長老老幼幼" },
    { "uuid": "bt0y7e8e", "segment": "國富兵彊内安外靜" },
    { "uuid": "wybfnsmp", "segment": "如山如川如岡如阜" },
    { "uuid": "woz6xnlv", "segment": "福如東海壽比南山" },
    { "uuid": "50hbksd6", "segment": "萬壽攸酢萬福攸同" },
    { "uuid": "aa4qntji", "segment": "天不愛道地不愛寶" },
    { "uuid": "nze6ah5h", "segment": "追琢其章金玉其相" },
    { "uuid": "1xsy3g2b", "segment": "王道蕩蕩聖謨洋洋" },
    { "uuid": "068ayhp8", "segment": "一人有慶萬壽無疆" },
    { "uuid": "rmkks2hb", "segment": "五辰順撫庶績其凝" },
    { "uuid": "a8gixvyw", "segment": "自天祐之吉無不利" },
    { "uuid": "g3mkwzk2", "segment": "四海共之萬世傳之" },
    { "uuid": "u8vg4iif", "segment": "澤及當辰恩垂萬世" },
    { "uuid": "rchszq94", "segment": "内四字十七號" },
    { "uuid": "5ugh4xhj", "segment": "元亨利貞" },
    { "uuid": "cza3vlho", "segment": "福履綏將" },
    { "uuid": "bghxl1xk", "segment": "帝德廣運" },
    { "uuid": "i763v9s0", "segment": "利用厚生" },
    { "uuid": "bgoz50ey", "segment": "中和位育" },
    { "uuid": "pdvj0n00", "segment": "斂福錫民" },
    { "uuid": "q8yiuqo6", "segment": "四方爲則" },
    { "uuid": "0fu41f27", "segment": "剛健中正" },
    { "uuid": "a58spu92", "segment": "家給人足" },
    { "uuid": "e6dubxxu", "segment": "川至山增" },
    { "uuid": "q0dgh53v", "segment": "天下大同" },
    { "uuid": "amnbzi1g", "segment": "萬世永賴" },
    { "uuid": "ey9zvcrj", "segment": "萬物資生" },
    { "uuid": "kpd42qfz", "segment": "解慍阜財" },
    { "uuid": "fqdmdx2b", "segment": "悠久無疆" },
    { "uuid": "7zuffwlb", "segment": "壽考萬年" },
    { "uuid": "jzbigwt4", "segment": "洧國利民" },
    { "uuid": "o5g8mw4r", "segment": "〇二十年" },
    { "uuid": "qgb0k4uc", "segment": "諭古號銅錢日久儲貯不免轉成頑弊曷若倂行攺鑄" },
    { "uuid": "5nujxzbn", "segment": "因念在京工匠數少不妨于河內原鑄場局再設鑪" },
    { "uuid": "tvpao5wn", "segment": "場不惟工匠人多便於趨事而小民得以傭工爲食" },
    { "uuid": "2tnzdbgf", "segment": "" }
  ],
