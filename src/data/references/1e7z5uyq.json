  "segments": [
    { "uuid": "wcnfjiyr", "segment": "2º Une pièce de cuivre jaune, au chiffre Minh-mang, ronde," },
    { "uuid": "xi401zbc", "segment": "portant au revers les caractères" },
    { "uuid": "ikkpqvpa", "segment": "金玉其相追琢" },
    { "uuid": "eob2hi7d", "segment": "其章" },
    { "uuid": "366f7ab9", "segment": "kim ngọc kỳ tương truy trác kỳ chương. « Le métal," },
    { "uuid": "lheghlvz", "segment": "comme toute chose précieuse, ne brille de son éclat qu'à l'aide" },
    { "uuid": "59dc9n2x", "segment": "du travail du joaillier, » figure exprimant que les plus belles" },
    { "uuid": "hgrjeuoc", "segment": "qualités, sans l'éducation, ne sont qu'imparfaites et grossières." },
    { "uuid": "iqd7j7ht", "segment": "Son diamètre est dé 51 millimètres." }
  ],
