  "segments": [
    { "uuid": "dq5v4tcy", "segment": "The two above coins were issued by King M" },
    { "uuid": "o2dtxpsj", "segment": "INH-MANG" },
    { "uuid": "ls4fota5", "segment": "(1820-1838)." },
    { "uuid": "2eadt7mb", "segment": "The custom of casting medals with inscrip-" },
    { "uuid": "he2e8cp5", "segment": "tions on the reverse, such as" },
    { "uuid": "z0a7wr00", "segment": "金 玉 其 相 追 琢 其 章" },
    { "uuid": "zha8qvii", "segment": "or" },
    { "uuid": "3jgafv6s", "segment": "風 調 雨 順 國 泰 民 安" },
    { "uuid": "3yruv8kj", "segment": "was followed by this king; but they" },
    { "uuid": "cd1mc3l3", "segment": "never went into circulation." }
  ],
