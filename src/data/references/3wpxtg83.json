  "maxims": [
    { "uuid": "ixvzdp6v", "segment": "Équité réciproque des princes et des sujets; affection réciproque des pères et des enfants" },
    { "uuid": "i93217p7", "segment": "Estimer les hommes d'un talent et d'une vertu peu ordinaire (aimer et rechercher les hommes sage); aimer ses parents (chérir ses proches); jouir de la paix; profiter de la bonne fortune" },
    { "uuid": "q5hobbfw", "segment": "L'état prospère; la peuple tranquille; le vent et la pluie à propos et dans une juste measure" },
    { "uuid": "o2qqponq", "segment": "(Puissiez-vous jouir des) trois souhaits de Hoa, (ainsi que des) neuf similitudes de Thiên bảo" },
    { "uuid": "uaz39591", "segment": "Obtenir le trône; acquérir l'opulence; gagner une bonne renommée; atteindre le longévité" },
    { "uuid": "muuzk32t", "segment": "Les six trésors de la nature ont été grandement améliorés; les trois occupations sont bien réglées" },
    { "uuid": "hov4yrxv", "segment": "Éminemment juste, éminemment irréprochable, sans esprit de parti, sans incliner plus d'un côté que de l'autre" },
    { "uuid": "sahho0en", "segment": "À l'empereur, à l'empereur, dix mille fois dix milles ans de vie" },
    { "uuid": "4aqdvu02", "segment": "Profondément vertueux et parfait, avec un maintien grave et une démarche respectueuse" },
    { "uuid": "s8pnyg48", "segment": "Que les fleuves aient un courant invariablement favorable; que les grains arrivent à maturité et en abondance chaque année" },
    { "uuid": "2z84bcmz", "segment": "Aimer ses parents; respecter ceux qui sont au-dessous de soi; honorer les veillards; chérir les jeunes enfants" },
    { "uuid": "p4u26dou", "segment": "Enrichir le royaume; affermir l'armée; la sûreté au dedans, la tranquillité au dehors" },
    { "uuid": "jko5x6ei", "segment": "(Que les biens s'accumulent et soient) comme une montagne, comme une fleuve, comme une crête de montagne, comme une monticule" },
    { "uuid": "xa530hbp", "segment": "La prosperité immense comme la mer orientale, la longévité comparable à la montagne du sud" },
    { "uuid": "xaxylg8g", "segment": "Dix milles année de vie accordées, comblé de tous les biens" },
    { "uuid": "10c9iwta", "segment": "Le ciel ne sera pas avare de ses bienfaits, ni la terre de ses trésors" },
    { "uuid": "tppm9wee", "segment": "Ses ornements sont ciselés et bien travaillés, l'or et les pierres précieuses en forment la matière" },
    { "uuid": "ppmr3mqo", "segment": "La voie du souverain est large et s'étend loin; les conseils des sages ont une grande portée" },
    { "uuid": "gwnm2qfm", "segment": "Le souverain sera heureux, il vivra dix mille ans, il vivra toujours" },
    { "uuid": "sh9fdswe", "segment": "En s'accommodant aux différentes saisons, tous les travaux seront parfaitement accomplis" },
    { "uuid": "k6oqxq6w", "segment": "Avec l'aide du ciel, tout devient favorable et prospère" },
    { "uuid": "c5vodtl0", "segment": "Tout l'empire lui rend hommage, tous les siècles proclameront son nom" },
    { "uuid": "v620m797", "segment": "Faire le bien dans le présent, étendre ses bienfaits à dix milles générations" },
    { "uuid": "h14pvl29", "segment": "Commencement, développement, affermissement, perfectionnement" },
    { "uuid": "2dir1y3t", "segment": "Jouir d'une félicité constant et assurée" },
    { "uuid": "tor8ac2f", "segment": "La Vertu de l'empereur est sans limite et toujours agissante" },
    { "uuid": "ve2sruy5", "segment": "Acquérir les objets nécessaires, se procurer les commodités de la vie" },
    { "uuid": "jblvyygh", "segment": "Par l'équilibre et l'harmonie, les choses sont à leur place et les êtres se propagent" },
    { "uuid": "mj7x5x5k", "segment": "Obtenir les (cinq) bonheurs, les faire partager au peuple" },
    { "uuid": "yd6x4clp", "segment": "Être la modèle de tout l'Empire" },
    { "uuid": "ilvzpsg1", "segment": "Ferme, fort, gardant le juste milieu, n'inclinant d'aucun côté" },
    { "uuid": "r97gdhdx", "segment": "Le peuple est dans l'abondance" },
    { "uuid": "hwj4rx5q", "segment": "Que tous les biens affluent et augmentent sans cesse" },
    { "uuid": "8euowcta", "segment": "Une grande concorde règne dans tout l'empire" },
    { "uuid": "93iq7ond", "segment": "Toutes les générations en recueilleront le fruit à jamais" },
    { "uuid": "dqpq76ol", "segment": "Tous les êtres tirent de la terre leur origine et leurs moyens de subsistance (lui doivent l'existance)" },
    { "uuid": "bh2lskki", "segment": "Étendre les haines, augmenter la richesse" },
    { "uuid": "zlbi23aa", "segment": "Son étendue et sa durée sont sans limite" },
    { "uuid": "s1apymmy", "segment": "Obtenir en récompense dix mille années de vie" },
    { "uuid": "gji6zrfk", "segment": "L'état prospère fait le peuple heureux" },
    { "uuid": "m269aw0x", "segment": "Avec l'aide du ciel, tout devient favorable et prospère" },
    { "uuid": "4mbfgvev", "segment": "Obtenir en récompense dix mille années de vie" },
    { "uuid": "r2khkj8m", "segment": "Aimer ses parents, respecter ceux qui sont au-dessous de soi, honorer les veillards, chérir les jeunes enfants" },
    { "uuid": "b15y92xb", "segment": "Ferme, fort, gardant le juste milieu, n'inclinant d'aucun côté." },
    { "uuid": "1n2djuv2", "segment": "Le ciel le comble de biens, lui protège, l'aide, lui confie le pouvoir" },
    { "uuid": "gc68h3jz", "segment": "(La vraie perfection est) élevée et brillante comme le ciel, large et profonde comme la terre" },
    { "uuid": "yvo61nte", "segment": "Dans tout l'empire il ne paraît aucun sujet d'inquiétude; cette prospérité s'étendra jusqu'aux générations futures" },
    { "uuid": "0pqaew9d", "segment": "La félicité et les honneurs viennent dans tout leur plénitude" },
    { "uuid": "bygcsqxj", "segment": "Tout le peuple lui voua une sincère affection" },
    { "uuid": "r5b3iv67", "segment": "Abondance de biens pour la communauté et le particuliers" },
    { "uuid": "n2b2hlnk", "segment": "Les neuf travaux doivent être accomplis avec ordre" }
  ],
